@using E_Commerce.Areas.Admin.ViewModels.CategoryVM
@model IEnumerable<CategoryItemVM>

@{
    ViewData["Title"] = "Categories Management";
}


<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" asp-action="Index">Admin</a>
                    </li>

                    <li class="breadcrumb-item active">Categories</li>
                </ol>
            </nav>
        </div>

        <a asp-action="Create" class="btn btn-primary d-flex align-items-center shadow-sm px-3 py-2">
            <i class="bi bi-plus-lg me-2"></i> <span>New Category</span>
        </a>
    </div>

    <div class="card admin-card border-0 shadow-sm overflow-hidden">

        <partial name="_Notification" />

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3 text-secondary small fw-bold text-uppercase" style="width: 15%">ID</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase" style="width: 55%">Category Name</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase text-end px-4" style="width: 30%">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4">
                                <span class="badge bg-light text-dark border fw-medium px-3 py-2">#@item.CategoryId</span>
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.CategoryName</div>
                            </td>
                            <td class="text-end px-4">
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Update"
                                       asp-route-categoryId="@item.CategoryId"
                                       class="btn btn-sm btn-outline-primary px-3">
                                        <i class="bi bi-pencil-square me-1"></i> Edit
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small">Showing @Model.Count() categories</span>
            </div>
        </div>
    </div>
</div>


<style>
    .table > :not(caption) > * > * {
        padding: 1rem 0.5rem;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02);
    }

    .btn-group .btn {
        border-radius: 6px !important;
        margin: 0 2px;
    }
</style>