@using E_Commerce.Areas.Admin.ViewModels.OrderVM
@model OrderDetailVM

@{
    ViewData["Title"] = "Order Details";
}

<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Admin</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">Orders</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Details</li>
                </ol>
            </nav>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3 fw-bold d-inline-flex align-items-center gap-1">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Sidebar: General & Shipping Information -->
        <div class="col-lg-4">
            <!-- General Info -->
            <div class="card admin-card border-0 shadow-sm mb-4 overflow-hidden">
                <div class="card-body p-4">
                    <h6 class="text-primary fw-bold text-uppercase mb-3 small tracking-wider">General Info</h6>

                    <div class="mb-3 d-flex justify-content-between align-items-center border-bottom pb-2">
                        <span class="text-muted small">Order ID:</span>
                        <span class="fw-bold text-dark font-monospace">#@Model.OrderId</span>
                    </div>

                    <div class="mb-3 d-flex justify-content-between align-items-center border-bottom pb-2">
                        <span class="text-muted small">Placed Date:</span>
                        <span class="fw-semibold text-dark small">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>

                    <div class="mb-3 d-flex justify-content-between align-items-center border-bottom pb-2">
                        <span class="text-muted small">Status:</span>
                        <div class="d-flex align-items-center gap-2">
                            @switch (Model.OrderStatusName)
                            {
                                case "Processing":
                                    <span class="badge status-badge bg-warning-subtle text-warning border border-warning-subtle-custom">Processing</span>
                                    break;
                                case "Shipped":
                                    <span class="badge status-badge bg-info-subtle text-info border border-info-subtle-custom">Shipped</span>
                                    break;
                                case "Delivered":
                                    <span class="badge status-badge bg-success-subtle text-success border border-success-subtle-custom">Delivered</span>
                                    break;
                                case "Cancelled":
                                    <span class="badge status-badge bg-danger-subtle text-danger border border-danger-subtle-custom">Cancelled</span>
                                    break;
                                default:
                                    <span class="badge status-badge bg-secondary-subtle text-secondary border border-secondary-subtle">Unknown</span>
                                    break;
                            }
                            <a asp-action="Update" asp-route-orderId="@Model.OrderId"
                               class="btn-edit-status transition-all" title="Update Status">
                                <i class="bi bi-pencil-fill"></i>
                            </a>
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted small">Payment Method:</span>
                        <span class="fw-semibold text-dark small"><i class="bi bi-credit-card text-secondary me-1"></i>@Model.PaymentMethodName</span>
                    </div>
                </div>
            </div>

            <!-- Shipping Details -->
            <div class="card admin-card border-0 shadow-sm overflow-hidden">
                <div class="card-body p-4">
                    <h6 class="text-primary fw-bold text-uppercase mb-4 small tracking-wider">Shipping Details</h6>

                    <div class="d-flex mb-3 align-items-start">
                        <div class="bg-light rounded-circle text-primary me-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px;">
                            <i class="bi bi-person-fill"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block small fw-bold text-uppercase mb-0">Recipient</small>
                            <p class="mb-0 fw-semibold text-dark">@Model.UserName</p>
                        </div>
                    </div>

                    <div class="d-flex mb-3 align-items-start">
                        <div class="bg-light rounded-circle text-primary me-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px;">
                            <i class="bi bi-telephone-fill"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block small fw-bold text-uppercase mb-0">Phone Number</small>
                            <p class="mb-0 fw-semibold text-dark font-monospace">@Model.PhoneNumber</p>
                        </div>
                    </div>

                    <div class="d-flex align-items-start">
                        <div class="bg-light rounded-circle text-primary me-3 d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px;">
                            <i class="bi bi-geo-alt-fill"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block small fw-bold text-uppercase mb-0">Delivery Address</small>
                            <p class="mb-0 fw-medium text-secondary small lh-base">@Model.Address</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content: Items Summary -->
        <div class="col-lg-8">
            <div class="card admin-card border-0 shadow-sm overflow-hidden mb-4">
                <div class="card-header bg-white py-3 border-bottom">
                    <h6 class="mb-0 fw-bold text-dark d-flex align-items-center gap-2">
                        <i class="bi bi-cart3 text-primary"></i> Items Summary
                    </h6>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3 text-secondary small fw-bold text-uppercase" style="width: 50%">Product</th>
                                <th class="py-3 text-secondary small fw-bold text-uppercase text-center" style="width: 18%">Price</th>
                                <th class="py-3 text-secondary small fw-bold text-uppercase text-center" style="width: 12%">Quantity</th>
                                <th class="py-3 text-secondary small fw-bold text-uppercase text-end px-4" style="width: 20%">Subtotal</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.OrderDetailItems)
                            {
                                <tr>
                                    <td class="px-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@item.Image" class="rounded border me-3 flex-shrink-0"
                                                 style="width: 48px; height: 48px; object-fit: cover;" alt="@item.ProductName" />
                                            <div class="text-truncate" style="max-width: 280px;">
                                                <span class="fw-bold text-dark d-block text-truncate">@item.ProductName</span>
                                                <small class="text-muted font-monospace">ID: #@item.ProductId</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center fw-medium text-dark">$@item.UnitPrice.ToString("N2")</td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-light text-dark border px-2 py-1 fw-normal">@item.Quantity</span>
                                    </td>
                                    <td class="text-end px-4 fw-bold text-dark">$@item.SubTotal.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>

                        <tfoot class="table-light border-top">
                            <tr>
                                <td colspan="3" class="text-end py-3 text-secondary fw-bold small text-uppercase">Total Amount:</td>
                                <td class="text-end px-4 py-3 text-primary fs-5 fw-bold font-monospace">$@Model.TotalAmount.ToString("N2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>

            <!-- Tip Block -->
            <div class="p-3 rounded-3 bg-primary-subtle border border-primary-subtle-custom d-flex align-items-start">
                <i class="bi bi-info-circle-fill text-primary me-3 fs-5 mt-0"></i>
                <div>
                    <h6 class="fw-bold text-primary mb-1 small text-uppercase tracking-wider">System Tip</h6>
                    <p class="mb-0 small text-primary opacity-85 lh-base">
                        As an administrator, you can manage Products, Categories and handle User orders from the sidebar menu.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-card {
        border-radius: 12px;
    }

    .tracking-wider {
        letter-spacing: 0.5px;
    }

    /* Edit Status Button Circular */
    .btn-edit-status {
        width: 26px;
        height: 26px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        border: 1px solid #dee2e6;
        background-color: #fff;
        color: #0d6efd;
        font-size: 0.75rem;
    }

        .btn-edit-status:hover {
            background-color: #f0f5ff;
            border-color: #80b3ff;
        }

    /* Custom Badge & Color States */
    .status-badge {
        padding: 0.4rem 0.6rem;
        font-weight: 600;
        font-size: 0.75rem;
        letter-spacing: 0.2px;
        border-radius: 6px;
    }

    .bg-warning-subtle {
        background-color: #fff8e6 !important;
        color: #b17a00 !important;
    }

    .border-warning-subtle-custom {
        border-color: #ffe69c !important;
    }

    .bg-info-subtle {
        background-color: #f0f9ff !important;
        color: #007094 !important;
    }

    .border-info-subtle-custom {
        border-color: #b9e6ff !important;
    }

    .bg-success-subtle {
        background-color: #f0fdf4 !important;
        color: #15803d !important;
    }

    .border-success-subtle-custom {
        border-color: #bbf7d0 !important;
    }

    .bg-danger-subtle {
        background-color: #fef2f2 !important;
        color: #b91c1c !important;
    }

    .border-danger-subtle-custom {
        border-color: #fecaca !important;
    }

    .bg-primary-subtle {
        background-color: #f0f5ff !important;
    }

    .border-primary-subtle-custom {
        border-color: #cfe2ff !important;
    }

    .pb-2 {
        padding-bottom: 0.625rem;
    }

    .mb-3 {
        margin-bottom: 0.875rem;
    }

    .p-3 {
        padding: 0.875rem;
    }

    .me-1 {
        margin-right: 0.375rem;
    }

    .transition-all {
        transition: all 0.2s ease-in-out;
    }

    @@media print {
        .btn, nav, .btn-edit-status, .bg-primary-subtle {
            display: none !important;
        }

        .card {
            box-shadow: none !important;
            border: 1px solid #dee2e6 !important;
        }
    }
</style>