@using E_Commerce.Areas.Admin.ViewModels.OrderVM
@model IEnumerable<OrderItemVM>

@{
    ViewData["Title"] = "Orders Management";
}


<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard"
                           asp-action="Index">Admin</a>
                    </li>

                    <li class="breadcrumb-item active">Orders</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="card admin-card border-0 shadow-sm overflow-hidden">

        <partial name="_Notification" />

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3 text-secondary small fw-bold text-uppercase">Order ID</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Date</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Payment</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Items</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Total</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase">Status</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase text-end px-4">Options</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4 fw-bold text-primary">#@item.OrderId</td>
                            <td class="text-muted small">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <span class="small fw-semibold"><i class="bi bi-credit-card me-1"></i> @item.PaymentMethodName</span>
                            </td>
                            <td><span class="badge rounded-pill bg-light text-dark border">@item.TotalItems Units</span></td>
                            <td><span class="fw-bold text-dark">$@item.TotalAmount.ToString("N2")</span></td>
                            <td>
                                @switch (item.OrderStatusName?.ToString())
                                {
                                    case "Processing":
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">
                                            <i class="bi bi-clock-history me-1"></i> Processing
                                        </span>
                                        break;
                                    case "Shipped":
                                        <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2">
                                            <i class="bi bi-truck me-1"></i> Shipped
                                        </span>
                                        break;
                                    case "Delivered":
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                            <i class="bi bi-check2-circle me-1"></i> Delivered
                                        </span>
                                        break;
                                    case "Cancelled":
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                                            <i class="bi bi-x-circle me-1"></i> Cancelled
                                        </span>
                                        break;

                                    default:
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                                            Unknown
                                        </span>
                                        break;
                                }
                            </td>
                            <td class="text-end px-4">
                                <a asp-action="Detail"
                                   asp-route-orderId="@item.OrderId"
                                   class="btn btn-sm btn-light border shadow-sm px-3 fw-bold">
                                    <i class="bi bi-eye me-1"></i> Detail
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white py-3 border-top">
            <div class="d-flex justify-content-between align-items-center">
                <p class="mb-0 text-muted small">Showing @Model.Count() orders</p>
            </div>
        </div>
    </div>
</div>


<style>
    .badge {
        font-weight: 600;
        letter-spacing: 0.3px;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0,0,0,0.01);
    }

    .btn-light:hover {
        background-color: #fff;
        border-color: #0d6efd;
        color: #0d6efd;
    }
</style>