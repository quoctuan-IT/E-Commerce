@using E_Commerce.Areas.Admin.ViewModels.OrderVM
@model OrderUpdateVM

@{
    ViewData["Title"] = "Update Order Status";
}

<div class="container-fluid p-0">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Dashboard" asp-action="Index">Admin</a></li>
            <li class="breadcrumb-item"><a asp-action="Index">Orders</a></li>
            <li class="breadcrumb-item active" aria-current="page">Update Status</li>
        </ol>
    </nav>

    <div class="row justify-content-center m-0">
        <div class="col-md-8 col-lg-5 p-0">
            <div class="card admin-card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-white py-3 border-bottom">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center me-3"
                             style="width: 44px; height: 44px;">
                            <i class="bi bi-pencil-square fs-5"></i>
                        </div>
                        <div>
                            <h5 class="mb-0 fw-bold text-dark">Update Order</h5>
                            <small class="text-primary fw-bold font-monospace">ORDER ID: #@Model.OrderId</small>
                        </div>
                    </div>
                </div>

                <div class="bg-light p-3 mx-4 mt-4 rounded-3 border border-light-subtle text-center">
                    <small class="text-secondary d-block small fw-bold text-uppercase mb-1">Order Date</small>
                    <span class="fw-semibold text-dark"><i class="bi bi-calendar3 me-1 text-muted"></i>@Model.OrderDate.ToString("dd/MM/yyyy")</span>
                </div>

                <form asp-action="Update" method="post">
                    <input type="hidden" asp-for="OrderId" />

                    <div class="card-body p-4">
                        <div class="mb-2">
                            <label asp-for="OrderStatusId" class="form-label text-secondary small fw-bold text-uppercase mb-2">
                                Transition Status to:
                            </label>
                            <div class="input-group custom-input-group">
                                <span class="input-group-text bg-white border-end-0 text-primary"><i class="bi bi-arrow-repeat"></i></span>
                                <select asp-for="OrderStatusId" class="form-select shadow-none">
                                    @foreach (var status in Model.OrderStatuses)
                                    {
                                        <option value="@status.OrderStatusId">@status.OrderStatusName</option>
                                    }
                                </select>
                            </div>
                            <div class="form-text text-muted small mt-2 d-flex align-items-start">
                                <i class="bi bi-info-circle-fill me-2 text-info mt-1"></i>
                                <span>Changing status will automatically trigger an email notification to the customer.</span>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-light p-4 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm d-inline-flex align-items-center gap-1 flex-grow-1 justify-content-center">
                            CONFIRM <i class="bi bi-check-lg"></i>
                        </button>
                        <a asp-action="Detail" asp-route-orderId="@Model.OrderId" class="btn btn-outline-secondary px-4 fw-bold">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-card {
        border-radius: 12px;
    }

    .custom-input-group .input-group-text {
        border-top-left-radius: 8px;
        border-bottom-left-radius: 8px;
    }

    .custom-input-group .form-select {
        border-top-right-radius: 8px;
        border-bottom-right-radius: 8px;
        padding: 0.6rem 1rem;
        font-size: 0.95rem;
    }

        .custom-input-group .form-select:focus {
            border-color: #86b7fe;
        }

    .me-1 {
        margin-right: 0.375rem;
    }

    .mt-2 {
        margin-top: 0.625rem;
    }
</style>