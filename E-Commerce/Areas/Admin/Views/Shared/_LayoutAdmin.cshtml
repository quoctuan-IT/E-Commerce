<!DOCTYPE html>

<html lang="en">

<head>
    <title>@ViewData["Title"] - Admin</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="icon" type="image/png" href="~/images/icons/icon-IT.png" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css">

    <style>
        :root {
            --sidebar-width: 250px;
        }

        body {
            background-color: #f4f7f6;
            font-family: 'Inter', sans-serif;
        }

        .sidebar {
            background-color: #212529;
            min-height: 100vh;
            transition: all 0.3s;
        }

        .nav-link {
            color: rgba(255,255,255,.75);
            padding: 12px 20px;
            border-radius: 8px;
            margin: 4px 10px;
            display: flex;
            align-items: center;
            transition: 0.2s;
        }

            .nav-link:hover {
                color: #fff;
                background-color: rgba(255,255,255,.1);
            }

            .nav-link.active {
                background-color: #0d6efd !important;
                color: white !important;
            }

            .nav-link i {
                font-size: 1.2rem;
                margin-right: 12px;
            }

        .content-area {
            padding: 30px;
            min-height: 100vh;
        }

        .admin-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }

        hr.sidebar-divider {
            margin: 1rem 1rem;
            color: rgba(255,255,255,.15);
        }
    </style>


    @RenderSection("Styles", required: false)


</head>

<body>
    <div class="container-fluid">
        <div class="row flex-nowrap">

            <div class="col-auto col-md-3 col-xl-2 px-0 sidebar shadow">
                <div class="d-flex flex-column align-items-center align-items-sm-start pt-4 text-white min-vh-100 sticky-top">

                    <a asp-controller="Dashboard"
                       asp-action="Index"
                       class="d-flex align-items-center pb-4 mb-md-0 me-md-auto text-white text-decoration-none px-4">
                        <img src="~/images/icons/icon-IT.png" alt="Admin" width="35" height="35" class="rounded-circle shadow-sm">
                        <span class="fs-5 fw-bold ms-2 d-none d-sm-inline ls-1">ADMIN</span>
                    </a>

                    <ul class="nav nav-pills flex-column mb-sm-auto mb-0 align-items-center align-items-sm-start w-100" id="menu">
                        <li class="w-100">
                            <a asp-controller="Dashboard"
                               asp-action="Index"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                                <i class="bi bi-speedometer2"></i> <span class="d-none d-sm-inline">Dashboard</span>
                            </a>
                        </li>

                        <li class="w-100">
                            <a asp-controller="Category"
                               asp-action="Index"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")">
                                <i class="bi bi-tags"></i> <span class="d-none d-sm-inline">Categories</span>
                            </a>
                        </li>

                        <li class="w-100">
                            <a asp-controller="Product"
                               asp-action="Index"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")">
                                <i class="bi bi-box-seam"></i> <span class="d-none d-sm-inline">Products</span>
                            </a>
                        </li>

                        <li class="w-100">
                            <a asp-controller="User"
                               asp-action="Index"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Account" ? "active" : "")">
                                <i class="bi bi-people"></i> <span class="d-none d-sm-inline">User</span>
                            </a>
                        </li>

                        <li class="w-100">
                            <a asp-controller="Order"
                               asp-action="Index"
                               class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Order" ? "active" : "")">
                                <i class="bi bi-cart-check"></i> <span class="d-none d-sm-inline">Orders</span>
                            </a>
                        </li>
                    </ul>

                    <hr class="sidebar-divider w-100">

                    @if (User.Identity != null && User.Identity.IsAuthenticated && !string.IsNullOrEmpty(@User.Identity.Name))
                    {
                        <div class="dropdown pb-4 px-4 w-100">
                            <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle py-2" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                    @User.Identity.Name.Substring(0, 1).ToUpper()
                                </div>

                                <span class="d-none d-sm-inline mx-1">@User.Identity.Name</span>
                            </a>

                            <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary mt-2" aria-labelledby="dropdownUser1">
                                <li>
                                    <a asp-area=""
                                       asp-controller="Home"
                                       asp-action="Index"
                                       class="dropdown-item py-2">
                                        <i class="bi bi-house-door me-2"></i> Shop
                                    </a>
                                </li>

                                <li>
                                    <a asp-area=""
                                       asp-controller="Account"
                                       asp-action="ChangePassword"
                                       class="dropdown-item py-2">
                                        <i class="bi bi-key me-2"></i> Password
                                    </a>
                                </li>

                                <li><hr class="dropdown-divider border-secondary"></li>

                                <li>
                                    <a asp-area=""
                                       asp-controller="Account"
                                       asp-action="Logout"
                                       class="dropdown-item py-2 text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i> Sign out
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </div>

            <div class="col py-0 content-area">
                <nav class="navbar navbar-expand navbar-light bg-transparent py-3 mb-4 border-bottom">
                    <div class="container-fluid">
                        <span class="navbar-brand mb-0 h1 fs-5 text-secondary">
                            <i class="bi bi-chevron-right me-2"></i> @ViewData["Title"]
                        </span>
                    </div>
                </nav>

                @RenderBody()
            </div>
        </div>
    </div>




    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>


    @RenderSection("Scripts", required: false)


</body>

</html>