<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Admin</title>

    <link rel="icon" type="image/png" href="~/images/icons/icon-IT.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css">

    <style>
        :root {
            --sidebar-width: 260px;
        }

        body {
            background-color: #f4f7f6;
            font-family: 'Inter', sans-serif;
        }

        /* Sidebar Responsive */
        .admin-sidebar {
            width: var(--sidebar-width);
            background-color: #212529;
            transition: transform 0.3s ease;
            z-index: 1045;
        }

        .nav-link {
            color: rgba(255,255,255,.75);
            padding: 12px 20px;
            border-radius: 8px;
            margin: 4px 15px;
            display: flex;
            align-items: center;
            transition: 0.2s;
        }

            .nav-link:hover {
                color: #fff;
                background-color: rgba(255,255,255,.1);
            }

            .nav-link.active {
                background-color: #0d6efd !important;
                color: white !important;
            }

            .nav-link i {
                font-size: 1.2rem;
                margin-right: 12px;
            }

        /* Main Content wrapper */
        .main-wrapper {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Desktop Layout */
        @@media (min-width: 992px) {
            .admin-sidebar

        {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            transform: translateX(0) !important;
        }

        .main-wrapper {
            margin-left: var(--sidebar-width);
        }

        .btn-toggle-sidebar {
            display: none;
        }

        }

        /* Mobile/Tablet Layout */
        @@media (max-width: 991.98px) {
            .admin-sidebar

        {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            transform: translateX(-100%);
        }

        .admin-sidebar.show {
            transform: translateX(0);
        }

        }

        .admin-card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- SIDEBAR -->
    <div class="admin-sidebar d-flex flex-column pt-4 text-white shadow" id="sidebarMenu">
        <!-- Logo Mobile -->
        <div class="d-flex align-items-center justify-content-between pb-4 px-4">
            <a asp-controller="Dashboard" asp-action="Index" class="d-flex align-items-center text-white text-decoration-none">
                <img src="~/images/icons/icon-IT.png" alt="Admin" width="35" height="35" class="rounded-circle shadow-sm">
                <span class="fs-5 fw-bold ms-2 ls-1">ADMIN</span>
            </a>
            <!-- Mobile -->
            <button type="button" class="btn-close btn-close-white d-lg-none" id="btnCloseSidebar" aria-label="Close"></button>
        </div>

        <!-- Menu Navigation -->
        <ul class="nav nav-pills flex-column mb-auto w-100" id="menu">
            <li class="w-100">
                <a asp-controller="Dashboard" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    <i class="bi bi-speedometer2"></i> <span>Dashboard</span>
                </a>
            </li>
            <li class="w-100">
                <a asp-controller="Category" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")">
                    <i class="bi bi-tags"></i> <span>Categories</span>
                </a>
            </li>
            <li class="w-100">
                <a asp-controller="Product" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Product" ? "active" : "")">
                    <i class="bi bi-box-seam"></i> <span>Products</span>
                </a>
            </li>
            <li class="w-100">
                <a asp-controller="User" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "User" ? "active" : "")">
                    <i class="bi bi-people"></i> <span>User</span>
                </a>
            </li>
            <li class="w-100">
                <a asp-controller="Order" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Order" ? "active" : "")">
                    <i class="bi bi-cart-check"></i> <span>Orders</span>
                </a>
            </li>
        </ul>

        <hr class="mx-3 my-3" style="color: rgba(255,255,255,.15);">

        <!-- User Dropdown -->
        @if (User.Identity != null && User.Identity.IsAuthenticated && !string.IsNullOrEmpty(User.Identity.Name))
        {
            <div class="dropdown pb-4 px-4 w-100">
                <a href="#" class="d-flex align-items-center text-white text-decoration-none dropdown-toggle py-2" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 32px; height: 32px; font-size: 0.8rem;">
                        @User.Identity.Name.Substring(0, 1).ToUpper()
                    </div>
                    <span class="mx-1">@User.Identity.Name</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-dark shadow border-secondary mt-2" aria-labelledby="dropdownUser1">
                    <li><a asp-area="" asp-controller="Home" asp-action="Index" class="dropdown-item py-2"><i class="bi bi-house-door me-2"></i> Shop</a></li>
                    <li><a asp-area="" asp-controller="Account" asp-action="ChangePassword" class="dropdown-item py-2"><i class="bi bi-key me-2"></i> Password</a></li>
                    <li><hr class="dropdown-divider border-secondary"></li>
                    <li><a asp-area="" asp-controller="Account" asp-action="Logout" class="dropdown-item py-2 text-danger"><i class="bi bi-box-arrow-right me-2"></i> Sign out</a></li>
                </ul>
            </div>
        }
    </div>

    <!-- MAIN CONTENT AREA -->
    <div class="main-wrapper">
        <!-- Top Navbar -->
        <nav class="navbar navbar-expand navbar-light bg-white py-3 px-4 shadow-sm border-bottom">
            <div class="container-fluid px-0">
                <!-- Mobile -->
                <button class="btn btn-outline-secondary me-3 btn-toggle-sidebar d-lg-none" type="button" id="btnOpenSidebar">
                    <i class="bi bi-list fs-5"></i>
                </button>

                <span class="navbar-brand mb-0 h1 fs-5 text-secondary">
                    <i class="bi bi-chevron-right me-2 d-none d-sm-inline"></i> @ViewData["Title"]
                </span>
            </div>
        </nav>

        <!-- Body Content -->
        <div class="p-4 flex-grow-1">
            @RenderBody()
        </div>
    </div>

    <div class="modal-backdrop fade show d-none" id="sidebarBackdrop" style="z-index: 1040;"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        const sidebar = document.getElementById('sidebarMenu');
        const btnOpen = document.getElementById('btnOpenSidebar');
        const btnClose = document.getElementById('btnCloseSidebar');
        const backdrop = document.getElementById('sidebarBackdrop');

        function toggleSidebar() {
            sidebar.classList.toggle('show');
            backdrop.classList.toggle('d-none');
        }

        if(btnOpen) btnOpen.addEventListener('click', toggleSidebar);
        if(btnClose) btnClose.addEventListener('click', toggleSidebar);
        if(backdrop) backdrop.addEventListener('click', toggleSidebar);
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>