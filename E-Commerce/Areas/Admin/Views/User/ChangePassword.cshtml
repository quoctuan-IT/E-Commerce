@using E_Commerce.Areas.Admin.ViewModels.UserVM
@model UserPasswordUpdateVM

@{
    ViewData["Title"] = "Security - Change Password";
}


<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card admin-card border-0 shadow-lg overflow-hidden">

                <div class="card-header bg-white border-bottom-0 pt-5 pb-2 text-center">
                    <div class="bg-warning-subtle text-warning rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3 shadow-sm"
                         style="width: 70px; height: 70px;">
                        <i class="bi bi-shield-lock-fill fs-1"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-1">SECURITY SETTINGS</h4>
                    <p class="text-muted small fw-semibold text-uppercase tracking-wider">Update your account credentials</p>
                </div>

                <div class="card-body px-4 pb-5">
                    <form asp-action="ChangePassword" method="post" class="needs-validation">
                        <div class="mb-4">
                            <label asp-for="UserId" class="form-label text-secondary small fw-bold text-uppercase mb-2">
                                UserId <span class="text-danger">*</span>
                            </label>

                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted px-3">
                                    <i class="bi bi-lock"></i>
                                </span>
                                <input asp-for="UserId"
                                       type="text" class="form-control bg-light border-start-0 py-2" readonly/>
                            </div>

                            <span asp-validation-for="UserId" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="CurrentPassword" class="form-label text-secondary small fw-bold text-uppercase mb-2">
                                Current Password <span class="text-danger">*</span>
                            </label>

                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted px-3">
                                    <i class="bi bi-lock"></i>
                                </span>
                                <input asp-for="CurrentPassword"
                                       type="password" class="form-control bg-light border-start-0 py-2"placeholder="••••••••" required autofocus />
                            </div>

                            <span asp-validation-for="CurrentPassword" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label text-secondary small fw-bold text-uppercase mb-2">
                                New Password <span class="text-danger">*</span>
                            </label>

                            <div class="input-group">
                                <span class="input-group-text bg-light border-end-0 text-muted px-3">
                                    <i class="bi bi-key"></i>
                                </span>
                                <input asp-for="NewPassword" type="password"
                                       class="form-control bg-light border-start-0 py-2"placeholder="Enter new password" required />
                            </div>

                            <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>

                            <div class="d-flex align-items-center mt-2 p-2 bg-light rounded-3 border">
                                <i class="bi bi-info-circle-fill text-info me-2"></i>
                                <small class="text-muted">Password must be at least 6 characters.</small>
                            </div>
                        </div>

                        <div class="mt-5 d-grid gap-2">
                            <button type="submit" class="btn btn-warning py-3 fw-bold text-dark shadow-sm">
                                <i class="bi bi-shield-check me-2"></i> UPDATE PASSWORD
                            </button>

                            <a asp-action="Index" class="btn btn-link text-decoration-none text-muted small mt-2 border-dark">
                                <i class="bi bi-arrow-left me-1"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>

            </div>
        </div>
    </div>
</div>


<style>
    .admin-card {
        border-radius: 20px;
    }

    .form-control {
        border-radius: 0 8px 8px 0;
        font-size: 0.95rem;
    }

    .input-group-text {
        border-radius: 8px 0 0 8px;
    }

    .form-control:focus {
        box-shadow: none;
        border-color: #dee2e6;
        background-color: #fff !important;
    }

    .btn-warning {
        transition: all 0.3s ease;
        border: none;
    }

        .btn-warning:hover {
            background-color: #ffca2c;
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 193, 7, 0.3) !important;
        }

    .tracking-wider {
        letter-spacing: 1px;
    }
</style>