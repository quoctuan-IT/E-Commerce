@using E_Commerce.Areas.Admin.ViewModels.UserVM
@model UserPasswordUpdateVM

@{
    ViewData["Title"] = "Security - Change Password";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8">
            <div class="card admin-card border-0 shadow-sm overflow-hidden">
                <div class="card-header bg-white border-bottom-0 pt-5 pb-3 text-center">
                    <div class="bg-warning-subtle text-warning rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width: 64px; height: 64px;">
                        <i class="bi bi-shield-lock-fill fs-2"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">SECURITY SETTINGS</h5>
                    <p class="text-muted small fw-semibold text-uppercase tracking-wider">Update user account credentials</p>
                </div>

                <div class="card-body px-4 pb-5 pt-2">
                    <form asp-action="ChangePassword" method="post">

                        <div class="mb-3">
                            <label asp-for="UserId" class="form-label text-secondary small fw-bold">USER ID</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-person-badge"></i></span>
                                <input asp-for="UserId" type="text" class="form-control bg-light border-start-0 text-secondary" readonly />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label text-secondary small fw-bold">CURRENT PASSWORD <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white text-muted border-end-0"><i class="bi bi-lock"></i></span>
                                <input asp-for="CurrentPassword" type="password" id="currentPwd" class="form-control border-start-0 border-end-0" placeholder="••••••••" required autofocus />
                                <button class="btn btn-outline-secondary border-start-0 bg-white text-muted" type="button" onclick="togglePasswordVisibility('currentPwd', 'iconCurrent')">
                                    <i class="bi bi-eye" id="iconCurrent"></i>
                                </button>
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="NewPassword" class="form-label text-secondary small fw-bold">NEW PASSWORD <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-white text-muted border-end-0"><i class="bi bi-key"></i></span>
                                <input asp-for="NewPassword" type="password" id="newPwd" class="form-control border-start-0 border-end-0" placeholder="Enter new password" required />
                                <button class="btn btn-outline-secondary border-start-0 bg-white text-muted" type="button" onclick="togglePasswordVisibility('newPwd', 'iconNew')">
                                    <i class="bi bi-eye" id="iconNew"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block"></span>

                            <div class="d-flex align-items-center mt-3 p-2 bg-light rounded border border-light-subtle">
                                <i class="bi bi-info-circle-fill text-info me-2 small"></i>
                                <small class="text-muted" style="font-size: 0.8rem;">Password must be at least 6 characters.</small>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning py-2-5 fw-bold text-dark shadow-sm transition-all">
                                <i class="bi bi-shield-check me-2"></i>UPDATE PASSWORD
                            </button>
                            <a asp-action="Index" class="btn btn-light bg-transparent border-0 text-secondary small fw-medium py-2">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-card {
        border-radius: 12px;
    }

    .form-control, .input-group-text {
        border-radius: 8px;
        font-size: 0.95rem;
        padding: 0.6rem 0.75rem;
    }

        .form-control:focus, .btn-outline-secondary:focus {
            border-color: #dee2e6;
            box-shadow: none;
        }

    .input-group:focus-within .input-group-text, .input-group:focus-within .form-control, .input-group:focus-within .btn {
        border-color: #0d6efd !important;
    }

    .btn-warning {
        background-color: #ffc107;
        border: none;
        border-radius: 8px;
    }

        .btn-warning:hover {
            background-color: #ffca2c;
            transform: translateY(-1px);
        }

    .py-2-5 {
        padding-top: 0.7rem;
        padding-bottom: 0.7rem;
    }

    .tracking-wider {
        letter-spacing: 0.5px;
    }

    .transition-all {
        transition: all 0.2s ease-in-out;
    }
</style>

<script>
    function togglePasswordVisibility(inputId, iconId) {
        const input = document.getElementById(inputId);
        const icon = document.getElementById(iconId);
        if (input.type === "password") {
            input.type = "text";
            icon.classList.replace("bi-eye", "bi-eye-slash");
        } else {
            input.type = "password";
            icon.classList.replace("bi-eye-slash", "bi-eye");
        }
    }
</script>