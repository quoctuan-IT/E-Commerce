@using E_Commerce.Areas.Admin.ViewModels.UserVM
@model IEnumerable<UserItemVM>

@{
    ViewData["Title"] = "User Management";
}


<div class="container-fluid p-0">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item">
                        <a asp-controller="Dashboard" 
                        asp-action="Index">Admin</a>
                        </li>

                    <li class="breadcrumb-item active">Users</li>
                </ol>
            </nav>
        </div>

        <a asp-action="Create" 
        class="btn btn-primary d-flex align-items-center shadow-sm px-3 py-2">
            <i class="bi bi-person-plus-fill me-2"></i> <span>Create User</span>
        </a>
    </div>

    <div class="card admin-card border-0 shadow-sm overflow-hidden">

        <partial name="_Notification" />

        <div class="card-header bg-white py-3 border-bottom-0">
            <div class="row align-items-center">
                <div class="col">
                    <h5 class="mb-0 fw-bold text-dark">Active Users</h5>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="px-4 py-3 text-secondary small fw-bold text-uppercase" style="width: 30%">User</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase" style="width: 20%">Contact</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase" style="width: 30%">Address</th>
                        <th class="py-3 text-secondary small fw-bold text-uppercase text-end px-4" style="width: 20%">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="px-4">
                                <div class="d-flex align-items-center">
                                    <div class="avatar-circle me-3 bg-primary-subtle text-primary fw-bold d-flex align-items-center justify-content-center rounded-circle"
                                         style="width: 40px; height: 40px; min-width: 40px;">
                                        @item.UserName?.Substring(0, 1).ToUpper()
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark">@item.UserName</div>
                                        <small class="text-muted">User ID: #@item.UserId</small>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="small fw-semibold text-dark"><i class="bi bi-telephone-outbound me-1 small"></i> @item.PhoneNumber</div>
                            </td>
                            <td>
                                <div class="text-muted small text-truncate" style="max-width: 250px;" title="@item.Address">
                                    <i class="bi bi-geo-alt me-1"></i> @item.Address
                                </div>
                            </td>
                            <td class="text-end px-4">
                                <a asp-action="ChangePassword"
                                   asp-route-userId="@item.UserId"
                                   class="btn btn-sm btn-outline-secondary px-3 d-inline-flex align-items-center">
                                    <i class="bi bi-key-fill me-1"></i> <span class="small fw-bold">Reset Password</span>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card-footer bg-white py-3">
            <div class="text-muted small">
                Showing @Model.Count() registered users
            </div>
        </div>
    </div>
</div>


<style>
    .admin-card {
        border-radius: 12px;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.01);
    }

    .avatar-circle {
        border: 1px solid rgba(13, 110, 253, 0.1);
        font-size: 0.9rem;
    }

    .btn-outline-secondary:hover {
        background-color: #f8f9fa;
        color: #0d6efd;
        border-color: #0d6efd;
    }
</style>