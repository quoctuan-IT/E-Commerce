@using E_Commerce.Areas.Admin.ViewModels.UserVM
@using E_Commerce.Models.ViewModels.AccountVM
@model ChangePasswordVM

@{
    ViewData["Title"] = "Change Password";
}


<!-- Breadcrumb -->
<div class="container">
    <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
        <a asp-controller="Account" asp-action="Profile" class="stext-109 cl8 hov-cl1 trans-04">
            Account &nbsp;<i class="fa fa-cog" aria-hidden="true"></i>
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <a asp-controller="Account" asp-action="Profile" class="stext-109 cl8 hov-cl1 trans-04">
            Profile &nbsp;<i class="fa fa-user-circle-o" aria-hidden="true"></i>
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <span class="stext-109 cl4">
            Change Password &nbsp;<i class="fa fa-pencil-square-o" aria-hidden="true"></i>
        </span>
    </div>
</div>


<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-5">
            <div class="card border-0 shadow-sm">

                <div class="card-header bg-white border-bottom py-4 text-center">
                    <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width: 60px; height: 60px; font-size: 1.5rem;">
                        <i class="fa fa-key"></i>
                    </div>
                    <h4 class="mb-0 font-weight-bold text-dark text-uppercase">Security</h4>
                    <p class="text-muted small mb-0 font-weight-bold">Change your account password</p>
                </div>

                <div class="card-body p-4">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <form asp-action="ChangePassword" method="post">
                        <div class="form-group mb-4">
                            <label class="text-muted small font-weight-bold text-uppercase mb-2" style="display: block;">
                                Current Password <span class="text-danger">*</span>
                            </label>

                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-white border-right-0"><i class="fa fa-lock text-muted"></i></span>
                                </div>

                                <input asp-for="@Model.CurrentPassword"
                                type="password"class="form-control border-left-0 py-4 font-weight-bold"placeholder="••••••••" required autofocus>
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger small font-italic"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label class="text-muted small font-weight-bold text-uppercase mb-2" style="display: block;">
                                New Password <span class="text-danger">*</span>
                            </label>

                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-white border-right-0"><i class="fa fa-shield text-muted"></i></span>
                                </div>
                                <input asp-for="@Model.NewPassword"
                                type="password"class="form-control border-left-0 py-4 font-weight-bold"placeholder="Enter new password" required>
                            </div>

                            <span asp-validation-for="NewPassword" class="text-danger small font-italic"></span>
                            <small class="form-text text-muted mt-2">
                                <i class="fa fa-info-circle mr-1"></i> Make sure it's at least 6 characters.
                            </small>
                        </div>

                        <div class="mt-5">
                            <button type="submit" class="btn btn-warning btn-block py-3 font-weight-bold shadow-sm text-white">
                                UPDATE PASSWORD &nbsp;<i class="fa fa-cog" aria-hidden="true"></i>
                            </button>

                            <a asp-controller="Account" 
                            asp-action="Profile" 
                            class="btn btn-link btn-block text-muted small mt-2">
                                <i class="fa fa-arrow-left mr-1"></i> Back to Profile
                            </a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>


<style>
    .card {
        border-radius: 15px;
    }

    .form-control {
        border-radius: 8px;
        border-color: #e9ecef;
    }

    .input-group-text {
        border-radius: 8px 0 0 8px;
        border-color: #e9ecef;
    }

    label {
        display: block !important;
        margin-bottom: 0.5rem;
    }

    .btn-warning {
        background-color: #ffc107;
        border: none;
    }

        .btn-warning:hover {
            background-color: #e0a800;
            transform: translateY(-1px);
        }
</style>