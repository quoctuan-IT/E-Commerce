@using E_Commerce.Models.ViewModels.AccountVM
@model LoginVM

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}


<!-- User Login -->
<form asp-action="Login" method="post">
    <img class="mt-4 mb-4" src="~/images/icons/icon-IT.png" alt="" width="200" height="200">

    <h1 class="h3 mb-3 fw-normal">LOGIN</h1>

    <!-- Validation Summary -->
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <!-- UserName -->
    <span asp-validation-for="@Model.UserName" class="text-danger mb-3"></span>
    <div class="form-floating mb-3">
        <input asp-for="@Model.UserName" type="tel" class="form-control" autofocus>
        <label asp-for="@Model.UserName" class="form-label">
            UserName<sup>*</sup>
        </label>
    </div>

    <!-- Password -->
    <span asp-validation-for="@Model.Password" class="text-danger mb-3"></span>
    <div class="form-floating mb-3">
        <input asp-for="@Model.Password" type="password" class="form-control">
        <label asp-for="@Model.Password" class="form-label">
            Password<sup>*</sup>
        </label>
    </div>

    <p class="mt-3 text-center">
        Dont't have account? <a asp-action="Register" class="text-info">Register</a>
    </p>

    <button class="btn w-100 py-2 text-black" type="submit" style="background-color: pink;">
        LOGIN
    </button>
</form>