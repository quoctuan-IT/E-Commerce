@using E_Commerce.Models.ViewModels.AccountVM
@model ProfileVM

@{
    ViewData["Title"] = "Profile";
}


<!-- Breadcrumb -->
<div class="container">
    <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
        <a asp-controller="Account" asp-action="Index" class="stext-109 cl8 hov-cl1 trans-04">
            Account &nbsp;<i class="fa fa-cog" aria-hidden="true"></i>
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <span class="stext-109 cl4">
            Profile &nbsp;<i class="fa fa-user-circle-o" aria-hidden="true"></i>
        </span>
    </div>
</div>


<!-- User Profile -->
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card border-0 shadow-sm">

                <partial name="_Notification" />

                <div class="card-header bg-white border-bottom py-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center">

                            @if (!string.IsNullOrEmpty(@Model.UserName))
                            {
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mr-3"
                                     style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                                    @Model.UserName.Substring(0, 1).ToUpper()
                                </div>
                            }
                            else
                            {
                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center mr-3"
                                     style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">
                                    User
                                </div>
                            }

                            <div>
                                <h5 class="mb-0 font-weight-bold text-dark">Welcome, <strong>@Model.UserName</strong></h5>
                                <p class="text-muted mb-0 small text-uppercase font-weight-bold">Personal Account</p>
                            </div>
                        </div>

                        <a asp-action="Logout"
                           class="btn btn-danger btn-sm font-weight-bold px-3 py-2 ml-1">
                            Sign out &nbsp;<i class="fa fa-sign-out" aria-hidden="true"></i>
                        </a>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row">
                        <div class="col-sm-6 mb-4 mb-sm-0">
                            <div class="p-3 border rounded bg-light h-100">
                                <label class="text-muted small font-weight-bold text-uppercase mb-2" style="display: block;">
                                    Phone Number
                                </label>

                                <div class="d-flex align-items-center">
                                    <i class="fa fa-phone text-primary mr-2"></i>
                                    <span class="h6 mb-0 font-weight-bold text-dark">@Model.PhoneNumber</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-sm-6">
                            <div class="p-3 border rounded bg-light h-100">
                                <label class="text-muted small font-weight-bold text-uppercase mb-2" style="display: block;">
                                    Shipping Address
                                </label>

                                <div class="d-flex align-items-center">
                                    <i class="fa fa-map-marker text-primary mr-2"></i>
                                    <span class="h6 mb-0 font-weight-bold text-dark">@Model.Address</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-top py-3">
                    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-sm-center">
                        <!-- Góc bên trái: Nút Admin -->
                        <div class="mb-2 mb-sm-0 w-100-mobile">
                            @if (User.IsInRole("Admin"))
                            {
                                <a asp-area="Admin"
                                   asp-controller="Dashboard"
                                   asp-action="Index"
                                   class="btn btn-success border font-weight-bold btn-custom-size">
                                    Admin &nbsp;<i class="fa fa-lock" aria-hidden="true"></i>
                                </a>
                            }
                        </div>

                        <!-- Góc bên phải: Các nút chức năng cá nhân -->
                        <div class="d-flex flex-column flex-sm-row style-gap w-100-mobile">
                            <a asp-controller="Order"
                               asp-action="MyOrders"
                               class="btn btn-secondary border font-weight-bold btn-custom-size">
                                Order History &nbsp;<i class="fa fa-history" aria-hidden="true"></i>
                            </a>

                            <a asp-controller="Account"
                               asp-action="UpdateProfile"
                               class="btn btn-info font-weight-bold btn-custom-size">
                                Update Profile &nbsp;<i class="fa fa-user" aria-hidden="true"></i>
                            </a>

                            <a asp-controller="Account"
                               asp-action="ChangePassword"
                               class="btn btn-warning font-weight-bold btn-custom-size">
                                Password &nbsp;<i class="fa fa-key" aria-hidden="true"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<style>
    .card {
        border-radius: 15px;
        overflow: hidden;
    }

    .btn {
        transition: all 0.3s;
    }

    .btn-outline-danger:hover {
        background-color: #dc3545;
        color: #fff;
    }

    .style-gap {
        gap: 10px;
    }

    .style-gap {
        gap: 10px;
    }

    @@media (min-width: 576px) {
        .btn-custom-size {
            min-width: 170px;
            text-align: center;
        }
    }

    @@media (max-width: 575.98px) {
        .w-100-mobile, .btn-custom-size {
            width: 100%;
        }
    }
</style>