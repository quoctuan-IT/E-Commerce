@using E_Commerce.Models.ViewModels.AccountVM
@model RegisterVM

@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}


<!-- User Register -->
<form asp-action="Register" method="post">
    <img class="mt-4 mb-4" src="~/images/icons/icon-IT.png" alt="" width="200" height="200">

    <h1 class="h3 mb-3 fw-normal">REGISTER</h1>

    <!-- Register Succeed -->
    <partial name="_Notification" />

    <!-- UserName -->
    <span asp-validation-for="@Model.UserName" class="text-danger mb-3"></span>
    <div class="form-floating mb-3">
        <input asp-for="@Model.UserName" type="text" class="form-control" required autofocus>
        <label asp-for="@Model.UserName" class="form-label">
            UserName<sup>*</sup>
        </label>
    </div>

    <!-- Password -->
    <span asp-validation-for="@Model.Password" class="text-danger mb-3"></span>
    <div class="form-floating mb-3">
        <input asp-for="@Model.Password" type="password" class="form-control" required>
        <label asp-for="@Model.Password" class="form-label">
            Password<sup>*</sup>
        </label>
    </div>

    <!-- Address -->
    <span asp-validation-for="@Model.Address" class="text-danger mb-3"></span>

    <div class="form-floating mb-3">
        <input asp-for="@Model.Address" type="text" class="form-control" required>
        <label asp-for="@Model.Address" class="form-label">
            Address<sup>*</sup>
        </label>
    </div>

    <!-- PhoneNumber -->
    <span asp-validation-for="@Model.PhoneNumber" class="text-danger mb-3"></span>

    <div class="form-floating mb-3">
        <input asp-for="@Model.PhoneNumber" type="tel" class="form-control" required>
        <label asp-for="@Model.PhoneNumber" class="form-label">
            PhoneNumber<sup>*</sup>
        </label>
    </div>

    <p class="mt-3 text-center">
        Already have account? <a asp-action="Login" class="text-info">Login</a>
    </p>

    <button class="btn w-100 py-2 text-black" type="submit" style="background-color: pink;">
        REGISTER
    </button>
</form>