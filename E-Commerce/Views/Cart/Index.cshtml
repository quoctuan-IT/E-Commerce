@using E_Commerce.Models.ViewModels.CartVM
@model IEnumerable<CartItemVM>

@{
    ViewData["Title"] = "Shopping Cart";
}


<!-- Breadcrumb -->
<div class="container">
    <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
        <a asp-controller="Product"
           asp-action="Index"
           class="stext-109 cl8 hov-cl1 trans-04">
            Shop &nbsp;<i class="fa fa-shopping-bag" aria-hidden="true"></i>
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <span class="stext-109 cl4">
            Shopping Cart &nbsp;<i class="fa fa-shopping-cart" aria-hidden="true"></i>
        </span>
    </div>
</div>


<!-- Shopping Cart -->
<div class="container py-5">

    @if (Model != null && Model.Any())
    {
        <div class="row">
            <div class="col-12 mb-4">
                <div class="card shadow-sm border-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead class="thead-light">
                                <tr>
                                    <th class="border-top-0 px-4">Product</th>
                                    <th class="border-top-0">Name</th>
                                    <th class="border-top-0 text-center">Price</th>
                                    <th class="border-top-0 text-center" style="width: 160px;">Quantity</th>
                                    <th class="border-top-0 text-center">Total</th>
                                    <th class="border-top-0 text-right px-4">Action</th>
                                </tr>
                            </thead>

                            <tbody>

                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="px-4">
                                            <a asp-controller="Product"
                                               asp-action="Detail"
                                               asp-route-productId="@item.ProductId">
                                                <img src="@item.Image"
                                                     class="img-fluid rounded border"
                                                     style="width: 70px; height: 70px; object-fit: cover;"
                                                     alt="@item.ProductName">
                                            </a>
                                        </td>

                                        <td class="font-weight-bold">
                                            <a asp-controller="Product"
                                               asp-action="Detail"
                                               asp-route-productId="@item.ProductId"
                                               class="text-dark text-decoration-none">
                                                @item.ProductName
                                            </a>
                                        </td>

                                        <td class="text-center">$ @item.UnitPrice</td>

                                        <td class="text-center">
                                            <div class="input-group input-group-sm mx-auto" style="width: 120px;">
                                                <div class="input-group-prepend">
                                                    <a asp-action="UpdateQuantity"
                                                       asp-route-productId="@item.ProductId" 
                                                       asp-route-quantity="-1"
                                                       class="btn btn-outline-danger">
                                                        <i class="fa fa-minus"></i>
                                                    </a>
                                                </div>

                                                <input type="text" class="form-control text-center bg-white" value="@item.Quantity" readonly>

                                                <div class="input-group-append">
                                                    <a asp-action="UpdateQuantity"
                                                       asp-route-productId="@item.ProductId" 
                                                       asp-route-quantity="1"
                                                       class="btn btn-outline-success">
                                                        <i class="fa fa-plus"></i>
                                                    </a>
                                                </div>
                                            </div>
                                        </td>

                                        <td class="text-center font-weight-bold text-primary">$ @item.Total</td>

                                        <td class="text-right px-4">
                                            <a asp-action="RemoveCart"
                                               asp-route-productId="@item.ProductId"
                                               class="btn btn-sm btn-outline-danger border-0 rounded-circle">
                                                <i class="fa fa-trash-o fa-lg"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }

                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-4">
                    <a asp-action="ClearCart"
                       class="btn btn-sm btn-danger border-0">
                        Delete Card &nbsp;<i class="fa fa-trash-o" aria-hidden="true"></i>
                    </a>
                </div>
            </div>

            <!-- Subtotal -->
            <div class="col-md-6 col-lg-4 ml-auto">
                <div class="card border-0 bg-light shadow-sm">
                    <div class="card-body p-4">
                        <h4 class="mtext-109 cl2 p-b-30">
                            Cart Subtotal
                        </h4>

                        <div class="flex-w flex-t p-t-27 p-b-33">
                            <div class="size-208">
                                <span class="mtext-101 cl2">
                                    Total:
                                </span>
                            </div>

                            <div class="size-209 p-t-1">
                                <span class="mtext-110 cl2">
                                    $ @Model.Sum(p => p.Total)
                                </span>
                            </div>
                        </div>

                        <a asp-controller="Order"
                           asp-action="Checkout"
                           class="flex-c-m stext-101 cl0 size-116 bg3 bor14 hov-btn3 p-lr-15 trans-04 pointer">
                            Checkout &nbsp;<i class="fa fa-credit-card" aria-hidden="true"></i>
                        </a>
                    </div>
                </div>

                <div class="mt-4">
                    <a asp-controller="Product"
                       asp-action="Index"
                       class="text-muted">
                        <i class="fa fa-chevron-left mr-2"></i>Back to Shop
                    </a>
                </div>
            </div>


        </div>
    }
    else
    {
        <partial name="_Notification" />

        <div class="text-center py-5 bg-white border rounded">
            <div class="mb-4">
                <i class="fa fa-shopping-basket text-dark" style="font-size: 4rem;"></i>
            </div>

            <h3 class="font-weight-bold">Your cart is empty!</h3>
            <p class="text-muted">Add some items to your cart to start shopping.</p>

            <a asp-controller="Product"
               asp-action="Index"
               class="btn btn-primary btn-lg mt-3 px-5">Shop Now</a>
        </div>
    }
</div>


<style>
    .table td, .table th {
        vertical-align: middle;
    }

    .btn-outline-danger:hover {
        background-color: #dc3545;
        color: white;
    }

    .card {
        border-radius: 0.5rem;
    }

    .input-group .form-control:focus {
        z-index: 0;
        box-shadow: none;
        border-color: #ced4da;
    }
</style>