@using E_Commerce.Models.ViewModels.OrderVM
@model CheckoutVM

@{
    ViewData["Title"] = "Checkout";
}


<!-- Breadcrumb -->
<div class="container">
    <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
        <a asp-controller="Product"
           asp-action="Index"
           class="stext-109 cl8 hov-cl1 trans-04">
            Shop &nbsp;<i class="fa fa-shopping-bag" aria-hidden="true"></i>
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <a asp-controller="Cart"
           asp-action="Index"
           class="stext-109 cl8 hov-cl1 trans-04">
            Shopping Cart &nbsp;<i class="fa fa-shopping-cart" aria-hidden="true"></i>
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <span class="stext-109 cl4">
            Checkout Order &nbsp;<i class="fa fa-credit-card" aria-hidden="true"></i>
        </span>
    </div>
</div>


<!-- Checkout -->
<div class="container py-5">

    <form asp-action="Checkout" method="post">
        <div class="row">
            <div class="col-md-12 col-lg-7">
                <div class="card border-0 shadow-sm p-4">
                    <h4 class="mb-4 font-weight-bold text-dark">Billing Details</h4>

                    <div class="d-flex justify-content-between align-items-center border p-3 rounded bg-light" style="max-width: 450px;">
                        <div>
                            <label asp-for="DefaultInformation"
                                   class="font-weight-bold mb-0" style="display: inline; cursor: pointer;">
                                Use default shipping address
                            </label>

                            <small class="form-text text-muted">Check this to use your saved profile information.</small>
                        </div>

                        <input asp-for="DefaultInformation"
                               class="form-check-input" type="checkbox" id="DefaultInformation" value="true" checked
                               style="display: inline-block; position: static; width: 20px; height: 20px; margin: 0; cursor: pointer;">
                    </div>

                    <div class="form-group mt-4 mb-4">
                        <label asp-for="Address"
                               class="font-weight-bold text-muted" id="labelAddress">
                            Shipping Address <span class="text-danger">*</span>
                        </label>

                        <div class="input-group mt-2">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white border"><i class="fa fa-map-marker text-muted"></i></span>
                            </div>

                            <input asp-for="Address"
                                   id="inputAddress" type="text" class="form-control border" placeholder="Address" required readonly>
                        </div>
                    </div>

                    <div class="form-group mb-2">
                        <label asp-for="PhoneNumber"
                               class="font-weight-bold text-muted" id="labelPhone">
                            Phone Number <span class="text-danger">*</span>
                        </label>

                        <div class="input-group mt-2">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-white border"><i class="fa fa-phone text-muted"></i></span>
                            </div>

                            <input asp-for="PhoneNumber"
                                   id="inputPhone" type="tel" class="form-control border" placeholder="Phone Number" required readonly>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <a asp-controller="Cart"
                       asp-action="Index"
                       class="text-muted text-decoration-none">
                        <i class="fa fa-chevron-left mr-2"></i>Back to Shopping Cart
                    </a>
                </div>
            </div>

            <div class="col-md-6 col-lg-4 ml-auto mt-5 mt-lg-0">
                <div class="card border-0 bg-light shadow-sm">
                    <div class="card-body p-4">
                        <h4 class="mtext-109 cl2 p-b-30">
                            Cart Totals
                        </h4>

                        <div class="flex-w flex-t bor12 p-t-15 p-b-30">
                            <div class="size-208 w-full-ssm">
                                <span class="stext-110 cl2">Shipping: </span>
                            </div>

                            <div class="size-209 p-r-18 p-r-0-sm w-full-ssm">
                                <div class="p-t-10">
                                    <div class="rs1-select2 rs2-select2 bor8 bg0 m-b-10 border rounded px-2">
                                        <select asp-for="PaymentMethodId"
                                                required class="form-control border-0 bg-transparent custom-select">
                                            <option value="" selected disabled hidden>Payment method</option>
                                            <option value="1">COD</option>
                                            <option value="2">Banking</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="flex-w flex-t p-t-27 p-b-33">
                            <div class="size-208">
                                <span class="mtext-101 cl2 h5 font-weight-bold">Total: </span>
                            </div>

                            <div class="size-209 p-t-1">
                                $&nbsp;<span id="cart-total" class="mtext-110 cl2 h5 font-weight-bold text-primary">0</span>
                            </div>
                        </div>

                        <button class="btn btn-dark btn-block py-3 font-weight-bold text-uppercase rounded-0 shadow">
                            CONFIRM ORDER &nbsp;<i class="fa fa-credit-card" aria-hidden="true"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </form>

</div>


<!-- Get Cart Summary to Checkout -->
@section Scripts {
    <script>
        $(document).ready(function () {
            const checkbox = $('#DefaultInformation');
            const inputs = $('#inputAddress, #inputPhone');
            const labels = $('#labelAddress, #labelPhone');

            function toggleInputs() {
                const isChecked = checkbox.is(':checked');

                inputs.prop('readonly', isChecked);

                if (isChecked) {
                    labels.addClass('text-muted');
                    inputs.addClass('bg-light');
                } else {
                    labels.removeClass('text-muted');
                    inputs.removeClass('bg-light');
                }
            }

            toggleInputs();

            checkbox.on('change', function () {
                toggleInputs();
            });
        });

        document.addEventListener('DOMContentLoaded', function () {

            fetch('/Cart/GetCartSummary')
                .then(res => res.json())
                .then(data => {
                    const totalEl = document.getElementById('cart-total');
                    const countEl = document.getElementById('cart-count');

                    if (totalEl) totalEl.innerText = data.total;
                    if (countEl) countEl.innerText = data.count;
            });

        });
    </script>
}


<style>
    .form-control:focus {
        box-shadow: none;
        border-color: #ced4da;
    }

    .input-group-text {
        border-right: none;
    }

    .card {
        border-radius: 8px;
    }

    .flex-w {
        display: flex;
        flex-wrap: wrap;
    }

    .flex-t {
        align-items: flex-start;
    }

    .size-208 {
        width: 35%;
    }

    .size-209 {
        width: 65%;
    }

    .bor12 {
        border-bottom: 1px solid #e6e6e6;
    }

    .p-b-13 {
        padding-bottom: 13px;
    }

    .p-t-15 {
        padding-top: 15px;
    }

    .p-b-30 {
        padding-bottom: 30px;
    }

    .p-t-27 {
        padding-top: 27px;
    }

    .p-b-33 {
        padding-bottom: 33px;
    }

    .custom-control-label::before,
    .custom-control-label::after {
        top: 0.25rem;
        left: -1.5rem;
    }
</style>