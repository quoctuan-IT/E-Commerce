@using E_Commerce.Models.ViewModels.OrderVM
@model OrderDetailVM

@{
    ViewData["Title"] = "My Order Detail";
}


<!-- Breadcrumb -->
<div class="container">
    <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
        <a asp-controller="Account"
        asp-action="Index"
        class="stext-109 cl8 hov-cl1 trans-04">
            Account &nbsp;<i class="fa fa-home" aria-hidden="true"></i>
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <a asp-controller="Order"
           asp-action="MyOrders"
           class="stext-109 cl8 hov-cl1 trans-04">
            My Order &nbsp;<i class="fa fa-list" aria-hidden="true"></i>
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <span class="stext-109 cl4">
            My Orders Detail &nbsp;<i class="fa fa-info-circle" aria-hidden="true"></i>
        </span>
    </div>
</div>


<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="font-weight-bold mb-0">Order Details</h2>
            <p class="text-muted">Order ID: 
                <span class="text-primary font-weight-bold">#@Model.OrderId</span>
                </p>
        </div>

        <a asp-controller="Order" 
        asp-action="MyOrders" 
        class="btn btn-outline-secondary btn-sm">
            <i class="fa fa-arrow-left mr-1"></i> Back to Orders
        </a>
    </div>

    <div class="row">
        <div class="col-lg-4 mb-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <h5 class="font-weight-bold mb-3">General Information</h5>
                    <ul class="list-unstyled mb-0">
                        <li class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Date:</span>
                            <span class="font-weight-bold">@Model.OrderDate.ToString("MMM dd, yyyy")</span>
                        </li>

                        <li class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Status:</span>

                            @switch (Model.OrderStatusName?.ToString())
                            {
                                case "Processing":
                                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-3 py-2">
                                        <i class="bi bi-clock-history me-1"></i> Processing
                                    </span>
                                    break;
                                case "Shipped":
                                    <span class="badge bg-info-subtle text-info border border-info-subtle px-3 py-2">
                                        <i class="bi bi-truck me-1"></i> Shipped
                                    </span>
                                    break;
                                case "Delivered":
                                    <span class="badge bg-success-subtle text-success border border-success-subtle px-3 py-2">
                                        <i class="bi bi-check2-circle me-1"></i> Delivered
                                    </span>
                                    break;
                                case "Cancelled":
                                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-3 py-2">
                                        <i class="bi bi-x-circle me-1"></i> Cancelled
                                    </span>
                                    break;

                                default:
                                    <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle px-3 py-2">
                                        Unknown
                                    </span>
                                    break;
                            }
                        </li>

                        <li class="d-flex justify-content-between mb-0">
                            <span class="text-muted">Payment:</span>
                            <span class="badge badge-light border">@Model.PaymentMethodName</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="font-weight-bold mb-3">Shipping Details</h5>

                    <div class="d-flex mb-3">
                        <i class="fa fa-phone text-primary mt-1 mr-3"></i>
                        <div>
                            <p class="small text-muted mb-0 font-weight-bold">PHONE NUMBER</p>
                            <p class="mb-0">@Model.PhoneNumber</p>
                        </div>
                    </div>

                    <div class="d-flex">
                        <i class="fa fa-map-marker text-primary mt-1 mr-3"></i>
                        <div>
                            <p class="small text-muted mb-0 font-weight-bold">DELIVERY ADDRESS</p>
                            <p class="mb-0">@Model.Address</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm overflow-hidden">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead class="thead-light">
                            <tr>
                                <th class="border-0 px-4">Product</th>
                                <th class="border-0 text-center">Price</th>
                                <th class="border-0 text-center">Qty</th>
                                <th class="border-0 text-right px-4">Subtotal</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="px-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@item.Image"
                                                 class="rounded border mr-3"
                                                 style="width: 50px; height: 50px; object-fit: cover;" />
                                            <span class="font-weight-bold text-dark">@item.ProductName</span>
                                        </div>
                                    </td>
                                    <td class="text-center">$@item.UnitPrice</td>
                                    <td class="text-center text-muted small">x @item.Quantity</td>
                                    <td class="text-right px-4 font-weight-bold text-dark">$@item.SubTotal</td>
                                </tr>
                            }
                        </tbody>

                        <tfoot class="bg-light">
                            <tr>
                                <td colspan="3" class="text-right font-weight-bold h5 py-3">Total Amount:</td>
                                <td class="text-right px-4 font-weight-bold h5 py-3 text-primary">$@Model.TotalAmount</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>


<style>
    .fa {
        width: 1.2rem;
        text-align: center;
    }

    .card {
        border-radius: 12px;
    }

    .table td {
        vertical-align: middle;
    }

    .card label {
        display: block !important;
    }
</style>