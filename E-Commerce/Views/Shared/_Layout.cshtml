<!DOCTYPE html>

<html lang="en">

<head>
    <partial name="_Head" />


    @RenderSection("Styles", required: false)


</head>

<body>

    <!-- Header -->
    <header class="header-v4">
        <!-- Header desktop -->
        <div class="container-menu-desktop">
            <!-- Topbar -->
            <div class="top-bar">
                <div class="content-topbar flex-sb-m h-full container">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <div class="mtext-110 left-top-bar">
                            Hi, <strong style="color: pink;">@User.Identity.Name ❤️</strong>.
                        </div>

                        <div class="right-top-bar flex-w h-full">
                            <a asp-controller="Account"
                               asp-action="Profile"
                               class="flex-c-m trans-04 p-lr-25">
                                Profile &nbsp;<i class="fa fa-user-circle-o" aria-hidden="true"></i>
                            </a>

                            <a asp-controller="Account"
                               asp-action="Logout"
                               class="flex-c-m trans-04 p-lr-25">
                                Sign out &nbsp;<i class="fa fa-sign-out" aria-hidden="true"></i>
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="mtext-110 left-top-bar">
                            Sign in to Order now!
                        </div>

                        <div class="right-top-bar flex-w h-full">
                            <a asp-controller="Account"
                               asp-action="Login"
                               class="flex-c-m trans-04 p-lr-25">
                                Sign in &nbsp;<i class="fa fa-sign-in" aria-hidden="true"></i>
                            </a>
                        </div>
                    }

                </div>
            </div>

            <div class="wrap-menu-desktop how-shadow1">
                <nav class="limiter-menu-desktop container">

                    <!-- Logo desktop -->
                    <a asp-controller="Home"
                       asp-action="Index"
                       class="logo">
                        <img src="~/images/icons/logo-01.png" alt="IMG-LOGO">
                    </a>

                    <!-- Menu desktop -->
                    <div class="menu-desktop">
                        <ul class="main-menu">
                            <li>
                                <a asp-controller="Home"
                                   asp-action="Index">
                                    Home &nbsp;<i class="fa fa-home" aria-hidden="true"></i>
                                </a>
                            </li>

                            <li class="active-menu label1" data-label1="sale">
                                <a asp-controller="Product"
                                   asp-action="Index">
                                    Shop
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Icon header -->
                    <div class="wrap-icon-header flex-w flex-r-m">
                        <div class="icon-header-item cl2 hov-cl1 trans-04 p-l-22 p-r-11 js-show-modal-search">
                            <i class="zmdi zmdi-search"></i>
                        </div>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="icon-header-item cl2 hov-cl1 trans-04 p-l-22 p-r-11 js-show-cart">
                                <i class="zmdi zmdi-shopping-cart"></i>
                            </div>
                        }
                    </div>
                </nav>
            </div>
        </div>

        <!-- Header Mobile -->
        <div class="wrap-header-mobile">
            <!-- Logo moblie -->
            <div class="logo-mobile">
                <a asp-controller="Home"
                   asp-action="Index">
                    <img src="~/images/icons/logo-01.png" alt="IMG-LOGO">
                </a>
            </div>

            <!-- Icon header -->
            <div class="wrap-icon-header flex-w flex-r-m m-r-15">
                <div class="icon-header-item cl2 hov-cl1 trans-04 p-r-11 js-show-modal-search">
                    <i class="zmdi zmdi-search"></i>
                </div>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="icon-header-item cl2 hov-cl1 trans-04 p-r-11 p-l-10 js-show-cart">
                        <i class="zmdi zmdi-shopping-cart"></i>
                    </div>
                }

            </div>

            <!-- Button show menu -->
            <div class="btn-show-menu-mobile hamburger hamburger--squeeze">
                <span class="hamburger-box">
                    <span class="hamburger-inner"></span>
                </span>
            </div>
        </div>

        <!-- Menu Mobile -->
        <div class="menu-mobile">
            <ul class="topbar-mobile">

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li>
                        <div class="mtext-110 left-top-bar">
                            Hi, <strong style="color: pink;">@User.Identity.Name ❤️</strong>.
                        </div>
                    </li>

                    <li>
                        <div class="right-top-bar flex-w h-full">
                            <a asp-controller="Account"
                               asp-action="Profile"
                               class="flex-c-m p-lr-10 trans-04">
                                Profile &nbsp;<i class="fa fa-user-circle-o" aria-hidden="true"></i>
                            </a>

                            <a asp-controller="Account"
                               asp-action="Logout"
                               class="flex-c-m p-lr-10 trans-04">
                                Sign out &nbsp;<i class="fa fa-sign-out" aria-hidden="true"></i>
                            </a>
                        </div>
                    </li>
                }
                else
                {
                    <li>
                        <div class="mtext-110 left-top-bar">
                            Sign in to Order now!
                        </div>
                    </li>

                    <li>
                        <div class="right-top-bar flex-w h-full">
                            <a asp-controller="Account"
                               asp-action="Login"
                               class="flex-c-m p-lr-10 trans-04">
                                Sign in &nbsp;<i class="fa fa-sign-in" aria-hidden="true"></i>
                            </a>
                        </div>
                    </li>
                }

            </ul>

            <ul class="main-menu-m">
                <li>
                    <a asp-controller="Home"
                       asp-action="Index">
                        Home &nbsp;<i class="fa fa-home" aria-hidden="true"></i>
                    </a>
                </li>

                <li>
                    <a asp-controller="Product"
                       asp-action="Index"
                       class="label1 rs1" data-label1="sale">
                        Shop
                    </a>
                </li>
            </ul>
        </div>

        <!-- Modal Search -->
        <div class="modal-search-header flex-c-m trans-04 js-hide-modal-search">
            <div class="container-search-header">
                <button class="flex-c-m btn-hide-modal-search trans-04 js-hide-modal-search">
                    <img src="~/images/icons/icon-close2.png" alt="CLOSE">
                </button>

                <form asp-controller="Product"
                      asp-action="Index"
                      class="wrap-search-header flex-w p-l-15" method="get">
                    <button class="flex-c-m trans-04">
                        <i class="zmdi zmdi-search"></i>
                    </button>

                    <input class="plh3" type="text" name="search" placeholder="Search">
                </form>

            </div>
        </div>
    </header>


    <!-- Cart -->
    <div class="wrap-header-cart js-panel-cart">
        <div class="s-full js-hide-cart"></div>

        <div class="header-cart flex-col-l p-l-65 p-r-25">
            <div class="header-cart-title flex-w flex-sb-m p-b-8">
                <span class="mtext-103 cl2">
                    Your Cart &nbsp;<i class="fa fa-shopping-cart" aria-hidden="true"></i>
                </span>
            </div>

            @await Component.InvokeAsync("Cart")

        </div>
    </div>


    @RenderBody()


    <!-- Footer -->
    <partial name="_Footer" />


    @RenderSection("Scripts", required: false)


</body>

</html>