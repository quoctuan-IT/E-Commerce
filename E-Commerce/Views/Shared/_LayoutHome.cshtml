<!DOCTYPE html>

<html lang="en">

<head>
    <partial name="_Head" />


    @RenderSection("Styles", required: false)


</head>

<body class="animsition">

    <!-- Header -->
    <header class="header-v3">
        <!-- Header desktop -->
        <div class="container-menu-desktop trans-03">
            <div class="wrap-menu-desktop">
                <nav class="limiter-menu-desktop p-l-45">
                    <!-- Logo desktop -->
                    <a asp-controller="Home"
                       asp-action="Index"
                       class="logo">
                        <img src="~/images/icons/logo-02.png" alt="IMG-LOGO">
                    </a>

                    <!-- Menu desktop -->
                    <div class="menu-desktop">
                        <ul class="main-menu">
                            <li class="active-menu">
                                <a asp-controller="Home"
                                   asp-action="Index">
                                    Home &nbsp;<i class="fa fa-home" aria-hidden="true"></i>
                                </a>
                            </li>

                            <li class="label1" data-label1="sale">
                                <a asp-controller="Product"
                                   asp-action="Index">
                                    Shop
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Icon header -->
                    <div class="wrap-icon-header flex-w flex-r-m h-full">
                        <div class="flex-c-m h-full p-r-25">
                            <div class="icon-header-item cl0 hov-cl1 trans-04 p-lr-11 js-show-modal-search">
                                <i class="zmdi zmdi-search"></i>
                            </div>
                        </div>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <div class="flex-c-m h-full p-lr-19 bor6">
                                <div class="icon-header-item cl0 hov-cl1 trans-04 p-lr-11 js-show-cart">
                                    <i class="zmdi zmdi-shopping-cart"></i>
                                </div>
                            </div>
                        }

                        <div class="flex-c-m h-full p-lr-19">
                            <div class="icon-header-item cl0 hov-cl1 trans-04 p-lr-11 js-show-sidebar">
                                <i class="zmdi zmdi-menu"></i>
                            </div>
                        </div>
                    </div>
                </nav>
            </div>
        </div>

        <!-- Header Mobile -->
        <div class="wrap-header-mobile">
            <!-- Logo moblie -->
            <div class="logo-mobile">
                <a asp-controller="Home"
                   asp-action="Index">
                    <img src="~/images/icons/logo-01.png" alt="IMG-LOGO">
                </a>
            </div>

            <!-- Icon header -->
            <div class="wrap-icon-header flex-w flex-r-m m-r-15">
                <div class="icon-header-item cl2 hov-cl1 trans-04 p-r-11 js-show-modal-search">
                    <i class="zmdi zmdi-search"></i>
                </div>

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <div class="icon-header-item cl2 hov-cl1 trans-04 p-r-11 p-l-10 js-show-cart">
                        <i class="zmdi zmdi-shopping-cart"></i>
                    </div>
                }

            </div>

            <!-- Button show menu -->
            <div class="btn-show-menu-mobile hamburger hamburger--squeeze">
                <span class="hamburger-box">
                    <span class="hamburger-inner"></span>
                </span>
            </div>
        </div>

        <!-- Menu Mobile -->
        <div class="menu-mobile">
            <ul class="topbar-mobile">

                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <li>
                        <div class="mtext-110 left-top-bar">
                            Hi, <strong style="color: pink;">@User.Identity.Name ❤️</strong>.
                        </div>
                    </li>

                    <li>
                        <div class="right-top-bar flex-w h-full">
                            <a asp-controller="Account"
                               asp-action="Profile"
                               class="flex-c-m p-lr-10 trans-04">
                                Profile &nbsp;<i class="fa fa-user-circle-o" aria-hidden="true"></i>
                            </a>

                            <a asp-controller="Account"
                               asp-action="Logout"
                               class="flex-c-m p-lr-10 trans-04">
                                Sign out &nbsp;<i class="fa fa-sign-out" aria-hidden="true"></i>
                            </a>
                        </div>
                    </li>
                }
                else
                {
                    <li>
                        <div class="mtext-110 left-top-bar">
                            Sign in to Order now!
                        </div>
                    </li>

                    <li>
                        <div class="right-top-bar flex-w h-full">
                            <a asp-controller="Account"
                               asp-action="Login"
                               class="flex-c-m p-lr-10 trans-04">
                                Sign in &nbsp;<i class="fa fa-sign-in" aria-hidden="true"></i>
                            </a>
                        </div>
                    </li>
                }

            </ul>

            <ul class="main-menu-m">
                <li>
                    <a asp-controller="Home"
                       asp-action="Index">
                        Home &nbsp;<i class="fa fa-home" aria-hidden="true"></i>
                    </a>
                </li>

                <li>
                    <a asp-controller="Product"
                       asp-action="Index"
                       class="label1 rs1" data-label1="sale">
                        Shop
                    </a>
                </li>
            </ul>
        </div>

        <!-- Modal Search -->
        <div class="modal-search-header flex-c-m trans-04 js-hide-modal-search">
            <div class="container-search-header">
                <button class="flex-c-m btn-hide-modal-search trans-04 js-hide-modal-search">
                    <img src="~/images/icons/icon-close2.png" alt="CLOSE">
                </button>

                <form class="wrap-search-header flex-w p-l-15" method="get"
                      asp-controller="Product"
                      asp-action="Index">
                    <button class="flex-c-m trans-04">
                        <i class="zmdi zmdi-search"></i>
                    </button>

                    <input class="plh3" type="text" name="search" placeholder="Search">
                </form>

            </div>
        </div>
    </header>


    <!-- Sidebar -->
    <aside class="wrap-sidebar js-sidebar">
        <div class="s-full js-hide-sidebar"></div>

        <div class="sidebar flex-col-l p-t-22 p-b-25">
            <div class="flex-r w-full p-b-30 p-r-27">
                <div class="fs-35 lh-10 cl2 p-lr-5 pointer hov-cl1 trans-04 js-hide-sidebar">
                    <i class="zmdi zmdi-close"></i>
                </div>
            </div>

            <div class="sidebar-content flex-w w-full p-lr-65 js-pscroll">
                <ul class="sidebar-link w-full">

                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="p-b-13">
                            <div class="mtext-111 cl2 hov-cl1 trans-04">
                                Hi, <strong style="color: pink;">@User.Identity.Name ❤️</strong>.
                            </div>
                        </li>

                        <li class="p-b-13">
                            <a asp-controller="Account"
                               asp-action="Profile"
                               class="mtext-110 cl2 hov-cl1 trans-04">
                                Profile &nbsp;<i class="fa fa-user-circle-o" aria-hidden="true"></i>
                            </a>
                        </li>

                        <li class="p-b-13">
                            <a asp-controller="Account"
                               asp-action="Logout"
                               class="mtext-110 cl2 hov-cl1 trans-04">
                                Sign out &nbsp;<i class="fa fa-sign-out" aria-hidden="true"></i>
                            </a>
                        </li>
                    }
                    else
                    {
                        <li class="p-b-13">
                            <a asp-controller="Account"
                               asp-action="Login"
                               class="mtext-110 cl2 hov-cl1 trans-04">
                                Sign in &nbsp;<i class="fa fa-sign-in" aria-hidden="true"></i>
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </aside>


    <!-- Cart -->
    <div class="wrap-header-cart js-panel-cart">
        <div class="s-full js-hide-cart"></div>

        <div class="header-cart flex-col-l p-l-65 p-r-25">
            <div class="header-cart-title flex-w flex-sb-m p-b-8">
                <span class="mtext-103 cl2">
                    Your Cart &nbsp;<i class="fa fa-shopping-cart" aria-hidden="true"></i>
                </span>
            </div>

            @await Component.InvokeAsync("Cart")

        </div>
    </div>


    @RenderBody()


    <!-- Footer -->
    <partial name="_Footer" />


    @RenderSection("Scripts", required: false)


</body>

</html>